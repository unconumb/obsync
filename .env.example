# .env.example — copy to .env and fill in the keys for your configured AI backend.
#
# obsync loads .env from the current working directory at startup. Only the
# key for your configured ai.backend (see obsync.yml) is required — leave the
# others unset.
#
# SECURITY: Never commit .env to version control. Add it to .gitignore.

# Required when ai.backend: claude
ANTHROPIC_API_KEY=

# Required when ai.backend: openai
OPENAI_API_KEY=
